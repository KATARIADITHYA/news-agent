# PolitiSense Environment Configuration
# Copy this to .env and fill in your values

# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ChromaDB persistence path (default: ./chroma_db)
CHROMA_DB_PATH=./chroma_db

# Path to whitehouse CSV
WHITEHOUSE_CSV_PATH=../whitehouse_presidential_actions_full.csv

# Embedding model (runs locally, no API needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB collection name
CHROMA_COLLECTION_WHITEHOUSE=whitehouse_actions
